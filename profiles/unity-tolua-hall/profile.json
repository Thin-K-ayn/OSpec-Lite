{
  "version": 1,
  "id": "unity-tolua-hall",
  "displayName": "Unity + ToLua Hall",
  "description": "Repo-local reading workflow and authoring pack for Unity + ToLua hall repositories.",
  "documentLanguage": "zh-CN",
  "authoringPackRoot": ".oslite/docs/agents/authoring",
  "requiredInitFields": [
    "projectName",
    "bootstrapAgent"
  ],
  "requiredRepoPaths": [
    "Assets/_GameCenter/ClientLua/Main.lua",
    "Assets/_GameCenter/FrameWork/Behaviours/Launch.cs",
    "Assets/_GameCenter/LuaFramework/Scripts/Main.cs",
    "Assets/_GameCenter/_Resources/HallScene/main.unity"
  ],
  "agentWrapperFiles": {
    "codex": [
      ".codex/skills/oslite-fill-project-docs/SKILL.md"
    ],
    "claude-code": [
      ".claude/commands/oslite-fill-project-docs.md"
    ]
  },
  "outputs": [
    "AGENTS.md",
    "CLAUDE.md",
    ".codex/skills/oslite-fill-project-docs/SKILL.md",
    ".claude/commands/oslite-fill-project-docs.md",
    ".oslite/docs/project/overview.md",
    ".oslite/docs/project/architecture.md",
    ".oslite/docs/project/repo-map.md",
    ".oslite/docs/project/entrypoints.md",
    ".oslite/docs/project/glossary.md",
    ".oslite/docs/project/coding-rules.md",
    ".oslite/docs/agents/quickstart.md",
    ".oslite/docs/agents/change-playbook.md",
    ".oslite/docs/agents/authoring/doc-contract.md",
    ".oslite/docs/agents/authoring/project-brief.md",
    ".oslite/docs/agents/authoring/repo-reading-checklist.md",
    ".oslite/docs/agents/authoring/evidence-map.md",
    ".oslite/docs/agents/authoring/fill-project-docs.md",
    ".oslite/docs/agents/authoring/doc-task-checklist.json"
  ],
  "assets": [
    { "source": "templates/AGENTS.md", "target": "AGENTS.md", "mode": "managed-codex-section" },
    { "source": "templates/CLAUDE.md", "target": "CLAUDE.md", "mode": "managed-claude-section" },
    { "source": "wrappers/codex/SKILL.md", "target": ".codex/skills/oslite-fill-project-docs/SKILL.md" },
    { "source": "wrappers/claude/oslite-fill-project-docs.md", "target": ".claude/commands/oslite-fill-project-docs.md" },
    { "source": "templates/docs/project/overview.md", "target": ".oslite/docs/project/overview.md" },
    { "source": "templates/docs/project/architecture.md", "target": ".oslite/docs/project/architecture.md" },
    { "source": "templates/docs/project/repo-map.md", "target": ".oslite/docs/project/repo-map.md" },
    { "source": "templates/docs/project/entrypoints.md", "target": ".oslite/docs/project/entrypoints.md" },
    { "source": "templates/docs/project/glossary.md", "target": ".oslite/docs/project/glossary.md" },
    { "source": "templates/docs/project/coding-rules.md", "target": ".oslite/docs/project/coding-rules.md" },
    { "source": "templates/docs/agents/quickstart.md", "target": ".oslite/docs/agents/quickstart.md" },
    { "source": "templates/docs/agents/change-playbook.md", "target": ".oslite/docs/agents/change-playbook.md" },
    { "source": "authoring-pack/doc-contract.md", "target": ".oslite/docs/agents/authoring/doc-contract.md" },
    { "source": "authoring-pack/project-brief.md", "target": ".oslite/docs/agents/authoring/project-brief.md" },
    { "source": "authoring-pack/repo-reading-checklist.md", "target": ".oslite/docs/agents/authoring/repo-reading-checklist.md" },
    { "source": "authoring-pack/evidence-map.md", "target": ".oslite/docs/agents/authoring/evidence-map.md" },
    { "source": "authoring-pack/fill-project-docs.md", "target": ".oslite/docs/agents/authoring/fill-project-docs.md" },
    { "source": "authoring-pack/doc-task-checklist.json", "target": ".oslite/docs/agents/authoring/doc-task-checklist.json" }
  ]
}
